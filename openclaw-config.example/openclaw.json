{
  "meta": {
    "lastTouchedVersion": "2026.2.13"
  },
  "env": {
    "OPENROUTER_API_KEY": "<YOUR_OPENROUTER_API_KEY>"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/openai/gpt-4.1",
        "fallbacks": [
          "openrouter/openai/gpt-4o-mini",
          "openrouter/google/gemini-2.5-flash-lite"
        ]
      },
      "imageModel": {
        "primary": "openrouter/openai/gpt-4o-mini",
        "fallbacks": ["openrouter/google/gemini-2.5-flash-lite"]
      },
      "models": {
        "openrouter/moonshotai/kimi-k2": { "alias": "kimi" },
        "openrouter/moonshotai/kimi-k2.5": { "alias": "kimi25" },
        "openrouter/openai/gpt-4o-mini": { "alias": "mini" },
        "openrouter/google/gemini-2.5-flash-lite": { "alias": "flash" },
        "openrouter/openrouter/auto": { "alias": "auto" },
        "openrouter/openai/gpt-4.1": { "alias": "gpt41" },
        "openrouter/openai/gpt-5.1-codex": { "alias": "codex" },
        "openai-codex/gpt-5.3-codex": { "alias": "codex53" }
      },
      "workspace": "~/.openclaw/workspace",
      "contextTokens": 48000,
      "compaction": {
        "mode": "safeguard",
        "reserveTokensFloor": 12000,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 3000,
          "systemPrompt": "Session nearing compaction. Store any important operational context, pending tasks, or decisions to memory.",
          "prompt": "Write any lasting notes to memory/session-notes.md; reply with NO_REPLY if nothing to store."
        }
      },
      "heartbeat": {
        "every": "0",
        "model": "openrouter/google/gemini-2.5-flash-lite",
        "target": "none"
      },
      "subagents": {
        "maxConcurrent": 3,
        "archiveAfterMinutes": 45,
        "model": "openrouter/openai/gpt-4.1"
      }
    },
    "list": [
      {
        "id": "main",
        "identity": { "name": "Jarvis" },
        "subagents": { "allowAgents": ["forge", "instagram", "whatsapp"] },
        "model": "openrouter/openai/gpt-4.1"
      },
      {
        "id": "forge",
        "name": "forge",
        "model": "openai-codex/gpt-5.3-codex",
        "identity": { "name": "Forge" }
      },
      {
        "id": "instagram",
        "name": "instagram",
        "model": "openrouter/openai/gpt-4o-mini",
        "identity": { "name": "Eform Instagram Asistani" }
      },
      {
        "id": "whatsapp",
        "workspace": "~/.openclaw/workspace-whatsapp",
        "model": "openrouter/openai/gpt-4o-mini",
        "identity": { "name": "Eform WhatsApp Asistan" }
      }
    ]
  },
  "bindings": [
    { "agentId": "whatsapp", "match": { "channel": "whatsapp" } }
  ],
  "hooks": {
    "enabled": true,
    "path": "/hooks",
    "token": "<YOUR_HOOKS_TOKEN>",
    "allowRequestSessionKey": true,
    "transformsDir": "~/.openclaw/hooks/transforms",
    "mappings": [
      {
        "id": "instagram",
        "match": { "path": "instagram" },
        "action": "agent",
        "wakeMode": "now",
        "name": "Instagram DM",
        "sessionKey": "hook:instagram:{{senderId}}",
        "messageTemplate": "{{message}}",
        "deliver": false
      },
      {
        "id": "whatsapp-lifecycle",
        "match": { "channel": "whatsapp", "event": "lifecycle" },
        "action": "webhook",
        "url": "http://localhost:3001/webhook/openclaw/whatsapp",
        "method": "POST"
      }
    ]
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "auth": { "token": "<YOUR_GATEWAY_AUTH_TOKEN>" }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "<YOUR_TELEGRAM_BOT_TOKEN>",
      "dmPolicy": "allowlist",
      "allowFrom": ["<YOUR_TELEGRAM_CHAT_ID>"],
      "streaming": "off"
    },
    "whatsapp": {
      "dmPolicy": "open",
      "groupPolicy": "disabled",
      "sendReadReceipts": true,
      "textChunkLimit": 4000
    }
  }
}
