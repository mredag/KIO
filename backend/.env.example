# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_PATH=./data/kiosk.db

# Session
SESSION_SECRET=change-this-to-a-random-secret-in-production

# Admin Credentials (default)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Integration API Key (for OpenClaw/external integrations)
# Generate with: openssl rand -base64 32
# Legacy env var name (N8N_API_KEY) kept for deployment compatibility
N8N_API_KEY=change-this-to-a-secure-random-key

# WhatsApp Configuration (for coupon system)
# Phone number in international format without + (e.g., 905551234567 for Turkey)
WHATSAPP_NUMBER=905551234567

# WhatsApp Cloud API Credentials (Meta Business API)
# Get these from: https://developers.facebook.com/apps
# IMPORTANT: Keep these secret! Never commit to git.
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id_here
WHATSAPP_APP_SECRET=your_app_secret_here
WHATSAPP_VERIFY_TOKEN=create_random_string_for_webhook_verification

# Timezone Configuration
TZ=Europe/Istanbul

# Google Sheets (optional - configure in admin panel)
GOOGLE_SHEETS_CREDENTIALS=

# File Upload
MAX_VIDEO_SIZE=52428800
MAX_IMAGE_SIZE=5242880

# Instagram Configuration
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id
INSTAGRAM_VERIFY_TOKEN=spa-kiosk-instagram-verify

# Instagram Test Mode — only respond to whitelisted sender IDs
# Set INSTAGRAM_TEST_MODE=true and list comma-separated IDs to restrict
INSTAGRAM_TEST_MODE=false
INSTAGRAM_TEST_SENDER_IDS=

# OpenRouter API Key (for AI model routing)
OPENROUTER_API_KEY=your_openrouter_api_key

# OpenClaw Integration
OPENCLAW_IG_WEBHOOK_URL=http://127.0.0.1:18789/hooks/agent
OPENCLAW_HOOKS_TOKEN=your_openclaw_hooks_token
USE_OPENCLAW=true

# OpenAI API Key (for vector embeddings)
OPENAI_API_KEY=your_openai_api_key

# Telegram Bot (for admin escalation notifications)
# Create bot via @BotFather, get chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# OpenClaw Jarvis WebSocket (gateway auth token from openclaw.json)
OPENCLAW_JARVIS_ENABLED=true
OPENCLAW_GATEWAY_TOKEN=<your_gateway_token>
